{
  "name": "mediavault",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "watch:main": "tsc -w -p tsconfig.main.json",
    "watch:renderer": "tsc -w -p tsconfig.renderer.json",
    "electron": "nodemon --watch dist --exec node electron/dev-runner.cjs",
    "dev": "concurrently \"pnpm watch:main\" \"pnpm watch:renderer\" \"pnpm electron\"",
    "build": "npm run build:main && npm run build:renderer",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:css": "npx @tailwindcss/cli -i ./src/renderer/css/input.css -o ./src/renderer/css/output.css --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron": "^42.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "concurrently": "^10.0.3",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
